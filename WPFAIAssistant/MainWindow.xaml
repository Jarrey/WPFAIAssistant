<Window x:Class="WPFAIAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="WPF AI Assistant" Height="720" Width="1100"
        Background="#1e1e2e" Foreground="#cdd6f4"
        MinHeight="500" MinWidth="750">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Dark theme colours -->
        <SolidColorBrush x:Key="BgBrush"        Color="#1e1e2e"/>
        <SolidColorBrush x:Key="SurfaceBrush"   Color="#2a2a3e"/>
        <SolidColorBrush x:Key="BorderBrush"    Color="#45475a"/>
        <SolidColorBrush x:Key="AccentBrush"    Color="#89b4fa"/>
        <SolidColorBrush x:Key="TextBrush"      Color="#cdd6f4"/>
        <SolidColorBrush x:Key="MutedBrush"     Color="#a6adc8"/>
        <SolidColorBrush x:Key="RedBrush"       Color="#f38ba8"/>
        <SolidColorBrush x:Key="GreenBrush"     Color="#a6e3a1"/>

        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#181825"/>
            <Setter Property="Foreground"       Value="#cdd6f4"/>
            <Setter Property="CaretBrush"       Value="#89b4fa"/>
            <Setter Property="BorderBrush"      Value="#45475a"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"       Value="#181825"/>
            <Setter Property="Foreground"       Value="#cdd6f4"/>
            <Setter Property="CaretBrush"       Value="#89b4fa"/>
            <Setter Property="BorderBrush"      Value="#45475a"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ComboBox (full template so system chrome is replaced) ── -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="22"/>
                    </Grid.ColumnDefinitions>
                    <!-- arrow -->
                    <TextBlock Grid.Column="1" Text="▾"
                               Foreground="#a6adc8" FontSize="10"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root" Property="BorderBrush" Value="#89b4fa"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Root" Property="BorderBrush" Value="#89b4fa"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"          Value="#181825"/>
            <Setter Property="Foreground"          Value="#cdd6f4"/>
            <Setter Property="BorderBrush"         Value="#45475a"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="8,0,4,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Background border -->
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggle}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <!-- Selected item display -->
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <!-- Dropdown popup -->
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#2a2a3e"
                                            BorderBrush="#45475a"
                                            BorderThickness="1"
                                            CornerRadius="6"/>
                                    <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#585b70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Item container style -->
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"          Value="Transparent"/>
                    <Setter Property="Foreground"          Value="#cdd6f4"/>
                    <Setter Property="Padding"             Value="10,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}"
                                        CornerRadius="4"
                                        Margin="2,1">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#383858"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#313244"/>
                                        <Setter Property="Foreground" Value="#89b4fa"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#89b4fa"/>
            <Setter Property="Foreground"   Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="10,6"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#b4cffe"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#45475a"/>
                                <Setter Property="Foreground" Value="#6c7086"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#f38ba8"/>
        </Style>

        <Style x:Key="SubtleButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#45475a"/>
            <Setter Property="Foreground" Value="#cdd6f4"/>
        </Style>

        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#a6adc8"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Margin"       Value="0,0,0,3"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sessions + Settings sidebar -->
            <ColumnDefinition Width="240"/>
            <!-- Splitter -->
            <ColumnDefinition Width="4"/>
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Sessions panel -->
                    <RowDefinition Height="*" MinHeight="120"/>
                    <!-- Splitter -->
                    <RowDefinition Height="4"/>
                    <!-- Settings panel -->
                    <RowDefinition Height="Auto" MaxHeight="400"/>
                    <!-- Status bar -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#181825" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="🤖 WPF AI Assistant"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="Powered by Semantic Kernel"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Sessions Panel ── -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sessions header + New button -->
                    <Border Grid.Row="0" Padding="14,8,8,6"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="SESSIONS" Style="{StaticResource HeaderLabel}"
                                       VerticalAlignment="Center"/>
                            <Button Content="＋ New"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Right"
                                    Padding="8,3" FontSize="11"
                                    Command="{Binding NewSessionCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Session list -->
                    <ListBox Grid.Row="1"
                             x:Name="SessionListBox"
                             ItemsSource="{Binding Sessions}"
                             SelectedItem="{Binding ActiveSession, Mode=OneWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="SessionListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#313244"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2a2a40"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="10,5,6,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#cdd6f4"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="155"/>
                                        <TextBlock Text="{Binding UpdatedAtDisplay}"
                                                   Foreground="#6c7086"
                                                   FontSize="10"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="🗑"
                                            ToolTip="Delete session"
                                            FontSize="11"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#585b70"
                                            Cursor="Hand"
                                            Padding="4,2"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.DeleteSessionCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#f38ba820"/>
                                                                    <Setter Property="Foreground" Value="#f38ba8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Row splitter between sessions and settings -->
                <GridSplitter Grid.Row="2" Height="4"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}"
                              ResizeDirection="Rows"/>

                <!-- ── Settings Panel ── -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,4,14,8">
                        <!-- Settings collapsible header -->
                        <Border Padding="0,6,0,6" Cursor="Hand" x:Name="SettingsHeaderBorder"
                                MouseLeftButtonDown="SettingsHeader_Click">
                            <Grid>
                                <TextBlock Text="⚙  SETTINGS" Style="{StaticResource HeaderLabel}" VerticalAlignment="Center" Margin="0"/>
                                <TextBlock x:Name="SettingsToggleArrow" Text="▶" HorizontalAlignment="Right"
                                           Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="SettingsContent" Visibility="Collapsed" Margin="0,0,0,8">
                            <!-- API Key -->
                            <TextBlock Text="API Key" Style="{StaticResource HeaderLabel}"/>
                            <PasswordBox x:Name="ApiKeyBox"
                                         Style="{StaticResource DarkPasswordBox}"
                                         Height="32" Margin="0,0,0,10"
                                         PasswordChanged="ApiKeyBox_PasswordChanged"/>
                            <!-- Base URL -->
                            <TextBlock Text="Base URL" Style="{StaticResource HeaderLabel}"/>
                            <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource DarkTextBox}"
                                     Height="32" Margin="0,0,0,10"/>
                            <!-- Model -->
                            <TextBlock Text="Model" Style="{StaticResource HeaderLabel}"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding AvailableModels}"
                                          SelectedItem="{Binding SelectedModel}"
                                          Style="{StaticResource DarkComboBox}"
                                          Height="32"/>
                                <Button Grid.Column="2" Content="↻"
                                        Style="{StaticResource SubtleButton}"
                                        Width="32" Height="32" FontSize="16" Padding="0"
                                        ToolTip="Refresh model list"
                                        Command="{Binding RefreshModelsCommand}"/>
                            </Grid>
                            <!-- Presets -->
                            <TextBlock Text="Presets" Style="{StaticResource HeaderLabel}"/>
                            <WrapPanel Margin="0,0,0,10">
                                <Button Content="DeepSeek" Style="{StaticResource SubtleButton}"
                                        Margin="0,0,4,4" FontSize="11" Click="Preset_DeepSeek"/>
                                <Button Content="OpenAI" Style="{StaticResource SubtleButton}"
                                        Margin="0,0,4,4" FontSize="11" Click="Preset_OpenAI"/>
                                <Button Content="Claude" Style="{StaticResource SubtleButton}"
                                        Margin="0,0,4,4" FontSize="11" Click="Preset_Claude"/>
                            </WrapPanel>
                            <!-- Actions -->
                            <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,10"/>
                            <Button Content="🗑  Clear Chat" Style="{StaticResource SubtleButton}"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                    Command="{Binding ClearChatCommand}"/>
                            <Button Content="⛔ Stop Generation" Style="{StaticResource DangerButton}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding StopCommand}"
                                    IsEnabled="{Binding IsBusy}"/>
                        </StackPanel>

                        <!-- Skills collapsible header -->
                        <Separator Background="{StaticResource BorderBrush}" Margin="0,2,0,4"/>
                        <Border Padding="0,6,0,6" Cursor="Hand" x:Name="SkillsHeaderBorder"
                                MouseLeftButtonDown="SkillsHeader_Click">
                            <Grid>
                                <TextBlock Text="🧩 SKILLS" Style="{StaticResource HeaderLabel}" VerticalAlignment="Center" Margin="0"/>
                                <TextBlock x:Name="SkillsToggleArrow" Text="▶" HorizontalAlignment="Right"
                                           Foreground="{StaticResource MutedBrush}" FontSize="10" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="SkillsContent" Visibility="Collapsed">
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="↺ Rescan" FontSize="11"
                                        Style="{StaticResource SubtleButton}"
                                        Command="{Binding RescanSkillsCommand}"/>
                                <Button Grid.Column="2" Content="＋ Load" FontSize="11"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="LoadSkillFile_Click"/>
                            </Grid>
                            <!-- Skills list -->
                            <ItemsControl ItemsSource="{Binding Skills}"
                                          MaxHeight="200">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2,0,0" Padding="6,4"
                                                Background="#181825" CornerRadius="6"
                                                BorderBrush="#45475a" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="#cdd6f4" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Source}"
                                                               Foreground="#6c7086" FontSize="10"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="✕"
                                                        FontSize="10" Padding="4,2"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="#585b70" Cursor="Hand"
                                                        Command="{Binding DataContext.RemoveSkillCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="#f38ba820"/>
                                                                                <Setter Property="Foreground" Value="#f38ba8"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Status bar -->
                <Border Grid.Row="4" Background="#181825"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="14,8">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11" TextWrapping="Wrap"/>
                        <ProgressBar IsIndeterminate="{Binding IsBusy}"
                                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                                     Height="2" Margin="0,4,0,0"
                                     Background="Transparent"
                                     Foreground="{StaticResource AccentBrush}"
                                     BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ SPLITTER ══════════════════════════════════════════ -->
        <GridSplitter Grid.Column="1" Width="4"
                      HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}"/>

        <!-- ══ MAIN AREA ═════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- WebView2 console -->
            <wv2:WebView2 x:Name="ConsoleWebView" Grid.Row="0"/>

            <!-- Input area -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             x:Name="InputBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBox}"
                             AcceptsReturn="False"
                             Height="40"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             KeyDown="InputBox_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button Grid.Column="2"
                            Content="Send ↵"
                            Style="{StaticResource PrimaryButton}"
                            Height="40" Width="80"
                            Command="{Binding SendCommand}"
                            IsDefault="True"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

